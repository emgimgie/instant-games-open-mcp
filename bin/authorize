#!/usr/bin/env node

/**
 * TapTap OAuth Authorization Tool
 * Run this script to complete OAuth authorization manually
 */

import { DeviceFlowAuth } from '../dist/auth/deviceFlow.js';

async function main() {
  console.log('🔐 TapTap OAuth 授权工具\n');

  const environment = process.env.TDS_MCP_ENV || 'production';
  console.log(`📍 环境: ${environment}\n`);

  const auth = new DeviceFlowAuth(environment);

  try {
    // This will show QR code and wait for authorization
    const token = await auth.initialize();

    console.log('\n✅ 授权成功！');
    console.log('📁 Token 已保存，现在可以在 Claude Code 中使用了\n');
    process.exit(0);
  } catch (error) {
    console.error('\n❌ 授权失败:', error.message);
    process.exit(1);
  }
}

main();
